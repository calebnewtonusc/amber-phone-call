# ============================================================
# amber-phone-call
# Voice gateway. Twilio number hands incoming calls to
# ElevenLabs Conversational AI, which calls back into this
# server for tools (Amber's brain).
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://amber-phone-call.up.railway.app

# ── Twilio ───────────────────────────────────────────────────
# From twilio.com/console. Phone number in E.164 format.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── ElevenLabs Conversational AI ─────────────────────────────
# Get at elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# The Conversational AI agent ID. Create one at
# elevenlabs.io/app/conversational-ai and paste its ID here.
ELEVENLABS_AGENT_ID=

# ── Amber brain ──────────────────────────────────────────────
# URL of the running amber-agent server. Tool webhooks proxy
# here to fetch context, health scores, contact memory, etc.
AMBER_AGENT_URL=https://amber-agent.up.railway.app
# Shared secret for signing tool webhook calls
AMBER_AGENT_SECRET=

# ── Anthropic (optional, only if using custom LLM path) ──────
# When set, voice conversations route through Claude instead
# of the ElevenLabs built-in LLM. Adds ~400ms latency but
# gives Amber full personality and tool access.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Security ─────────────────────────────────────────────────
# Twilio request signature validation is on by default in prod.
# Set to "true" to bypass (local dev, ngrok).
SKIP_TWILIO_SIGNATURE=false

# Bearer token ElevenLabs must send on tool webhook calls.
TOOL_WEBHOOK_SECRET=
