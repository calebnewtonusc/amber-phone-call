# ============================================================
# amber-phone-call
# Voice adapter. Twilio phone call in, ElevenLabs voice out,
# real Amber brain in the middle (Claude + Perplexity embeddings
# + Perplexity deep search, hosted by the amber-agent server).
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://amber-phone-call-production.up.railway.app

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Set true for local dev / ngrok. Flip to false in production so
# Twilio request signatures are enforced.
SKIP_TWILIO_SIGNATURE=false

# ── ElevenLabs (voice only) ──────────────────────────────────
# Get at elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID. Default is Rachel. Override to any voice from
# elevenlabs.io/app/voice-library or your own cloned voice.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Amber brain ──────────────────────────────────────────────
# The amber-agent backend. This is where every turn of conversation
# is forwarded. It runs Claude, Perplexity embeddings for relational
# memory, and Perplexity search for deep research, plus all the
# other Amber tools (Todoist, Calendar, health, Clay, GitHub).
#
# Expected endpoints on the backend:
#   POST {AMBER_AGENT_URL}/api/voice-turn      { callSid, caller, userText, channel } -> { reply }
#   POST {AMBER_AGENT_URL}/api/voice-turn/end  { callSid } -> 2xx
AMBER_AGENT_URL=https://amber-agent.up.railway.app
# Shared bearer used on Authorization header when calling the brain.
AMBER_AGENT_SECRET=
